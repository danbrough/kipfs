headers = libgokipfs.h
staticLibraries.mingw  = libgokipfs.a libssl.a libcrypto.a
staticLibraries.linux  = libgokipfs.a

compilerOpts.linux=-fPIC -Wl,-Bsymbolic
compilerOpts.android=-fPIC -Wl,-Bsymbolic


linkerOpts.linux =  -Bsymbolic -ldl -lssl -lcrypto -l:libgokipfs.a
linkerOpts.android =  -Bsymbolic -lc -lm -ldl -lssl -lcrypto -lgokipfs
linkerOpts.android_x86 = -Lopenssl/libs/android386/lib -L./golib/build/native/android386
linkerOpts.android_arm32 = -Lopenssl/libs/androidArm/lib -L./golib/build/native/androidArm

linkerOpts.android_arm64 = -Lopenssl/libs/androidArm64/lib -L./golib/build/native/androidArm64
linkerOpts.android_x64 = -Lopenssl/libs/androidAmd64/lib -L./golib/build/native/androidAmd64

linkerOpts.mingw=-lm -l:libssl.a -l:libcrypto.a -l:libgokipfs.a
linkerOpts.linux_x64 = -Lopenssl/libs/linuxAmd64/lib -L./golib/build/native/linuxAmd64
linkerOpts.linux_arm32_hfp = -Lopenssl/libs/linuxArm/lib -L./golib/build/native/linuxArm
linkerOpts.linux_arm64 = -Lopenssl/libs/linuxArm64/lib -L./golib/build/native/linuxArm64




