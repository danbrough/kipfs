#include <stdio.h>


void print_test(const char *msg){
    printf("The message is %s\n",msg);
    //doSomething();
    printf("The other message is %s\n",KGetMessage());
}

int myFun(int i) {
  return i+1;
}

typedef int  (*MyFun)(int);

void accept_fun(MyFun f) {
  f(42);
}

MyFun supply_fun() {
  return myFun;
}
